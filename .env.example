# ==============================================================================
# Agent Platform Interoperability (interoperability/)
# ==============================================================================
# Used by Foundry deployment scripts, hosted agents, and Copilot Studio integration.
# See interoperability/README.md for setup guide.

# --- Azure AI Foundry Project ---
# Used by: deploy.py, verify_agents.py, stay agent, dining agent
# Get from: Azure AI Foundry portal -> Project -> Overview
# Format: https://<resource-name>.services.ai.azure.com/api/projects/<project-name>
PROJECT_ENDPOINT=
AZURE_RESOURCE_GROUP=

# --- Azure OpenAI (shared with A2A) ---
# Used by: hosted agents (stay, dining), native agent deployment, A2A orchestrator
# Format: https://<resource-name>.cognitiveservices.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview
# Optional: only works if disableLocalAuth is false on the Azure OpenAI resource.
# Our resource has disableLocalAuth=true, so this key is ignored. See src/README.md
# "Docker Authentication" section for details.
AZURE_OPENAI_API_KEY=

# --- Bing Search ---
# Used by: native agents (transport, poi, events) and hosted agents (stay, dining)
# Get from: Azure AI Foundry portal -> Project -> Connected Resources
# Format: /subscriptions/{{subscriptionID}}/resourceGroups/{{resourceGroupName}}/providers/Microsoft.CognitiveServices/accounts/{{foundryAccountName}}/projects/{{foundryProjectName}}/connections/{{foundryConnectionName}}
BING_PROJECT_CONNECTION_ID=

# --- Azure Container Registry ---
# Used by: build_images.py to push hosted agent Docker images
ACR_REGISTRY=

# --- Hosted Agent Container Images ---
# Set automatically by build_images.py, or set manually
# Format: <acr-registry>/<image-name>:<tag>
STAY_AGENT_IMAGE=
DINING_AGENT_IMAGE=
WEATHER_PROXY_IMAGE=

# --- Copilot Studio - Direct Line (Demo 1: Foundry -> Copilot Studio) ---
# Used by: weather-proxy hosted agent
# Get from: Copilot Studio -> Weather Agent -> Settings -> Security -> Web channel security
COPILOTSTUDIOAGENT__DIRECTLINE_SECRET=

# --- Copilot Studio - M365 Agents SDK (Demo 1 Option A - not currently active) ---
# Used by: pro-code workflow's CopilotStudioAgent for calling CS Weather Agent
# Currently blocked by S2S limitation; Direct Line is used instead.
# See interoperability/foundry/agents/weather/README.md for details.
# Azure AD App Registration for calling Copilot Studio agents
COPILOTSTUDIOAGENT__AGENTAPPID=
COPILOTSTUDIOAGENT__AGENTAPPSECRET=
COPILOTSTUDIOAGENT__TENANTID=
COPILOTSTUDIOAGENT__ENVIRONMENTID=
COPILOTSTUDIOAGENT__WEATHER__SCHEMANAME=

# --- Observability (optional, shared with A2A) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=


# ==============================================================================
# A2A Orchestration (src/)
# ==============================================================================
# Used by the A2A multi-agent travel planner.
# See src/README.md for setup guide.
#
# Note: AZURE_OPENAI_*, PROJECT_ENDPOINT, and APPLICATIONINSIGHTS_CONNECTION_STRING
# are shared with the Interoperability section above — no need to set them twice.

# --- Pre-provisioned Orchestrator Agent IDs ---
# Create by running: uv run python scripts/provision_azure_agents.py
ORCHESTRATOR_ROUTING_AGENT_ID=
ORCHESTRATOR_CLASSIFIER_AGENT_ID=
ORCHESTRATOR_PLANNER_AGENT_ID=
ORCHESTRATOR_QA_AGENT_ID=

# --- Service Principal for Docker Demo ---
# Required when running the A2A demo in Docker containers.
# Inside Docker, DefaultAzureCredential cannot use your host's az login session.
# Created via: az ad sp create-for-rbac --role "Cognitive Services OpenAI User"
# See src/README.md "Docker Authentication" section for full setup guide.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Azure Cosmos DB (optional) ---
# Used by: orchestrator state persistence
COSMOS_DB_CONNECTION_STRING=
COSMOS_DB_DATABASE_NAME=travel_planner

# --- Server Configuration ---
SERVER_URL=localhost

# --- Agent Ports ---
ORCHESTRATOR_AGENT_PORT=10000
INTAKE_CLARIFIER_AGENT_PORT=10007
POI_SEARCH_AGENT_PORT=10008
STAY_AGENT_PORT=10009
TRANSPORT_AGENT_PORT=10010
EVENTS_AGENT_PORT=10011
ROUTE_AGENT_PORT=10012
BUDGET_AGENT_PORT=10013
BOOKING_AGENT_PORT=10014
AGGREGATOR_AGENT_PORT=10015
VALIDATOR_AGENT_PORT=10016
DINING_AGENT_PORT=10017

# --- Session ---
SESSION_TTL_DAYS=7

# --- Observability (optional) ---
# Set to 'true' to enable OpenTelemetry instrumentation
ENABLE_INSTRUMENTATION=false
# OTLP exporter endpoint (optional, used if Azure Monitor not configured)
# Example: http://localhost:4317 for local Jaeger/Zipkin
OTEL_EXPORTER_OTLP_ENDPOINT=
